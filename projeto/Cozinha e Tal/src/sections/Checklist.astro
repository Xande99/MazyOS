---
/**
 * Checklist — "é pra você se", qualificador de audiência antes do preço.
 * Específico deste projeto — não faz parte da biblioteca reutilizável.
 */
interface Props {
  titulo: string;
  itens: string[];
}

const { titulo, itens } = Astro.props;
---

<section class="container-du section-y">
  <h2 class="reveal text-center text-3xl font-bold text-text md:text-4xl">{titulo}</h2>
  <ul class="mx-auto mt-10 flex max-w-2xl flex-col gap-4">
    {itens.map((item, i) => (
      <li
        class="reveal flex items-start gap-3"
        data-reveal-delay={(i * 0.06).toFixed(2)}
      >
        <span
          aria-hidden="true"
          class="mt-0.5 flex h-6 w-6 flex-none items-center justify-center rounded-full bg-brand text-sm font-bold text-brand-contrast"
        >
          ✓
        </span>
        <p class="text-lg text-text">{item}</p>
      </li>
    ))}
  </ul>
</section>
