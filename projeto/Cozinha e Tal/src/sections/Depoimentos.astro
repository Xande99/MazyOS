---
/**
 * Depoimentos — PENDÊNCIA DE CONTEÚDO REAL (ver briefing.md e
 * `.claude/decisions.md`). NÃO preencher com depoimento fabricado —
 * nome/negócio inventado é risco jurídico e de reputação (mesmo
 * princípio do NOTES.md de duPolvo-vault/components/sections/
 * testimonials-columns). Estrutura pronta pra receber os depoimentos
 * reais assim que o cliente enviar (prints, avaliações, mensagens).
 *
 * Quando o conteúdo real chegar: substituir os `PLACEHOLDER` abaixo por
 * itens `{ nome, texto }` reais e trocar os cards tracejados por
 * `<blockquote>`/`<cite>` com o texto de verdade — ver o padrão de
 * "testimonials-columns" no Vault pra evoluir isso pra scroll/marquee se
 * o volume de depoimentos justificar.
 */
interface Props {
  titulo: string;
}

const { titulo } = Astro.props;
const PLACEHOLDER_COUNT = 3;
---

<section class="container-du section-y">
  <h2 class="reveal text-center text-3xl font-bold text-text md:text-4xl">{titulo}</h2>
  <p class="reveal mx-auto mt-3 max-w-prose text-center text-text-muted">
    Depoimentos reais de quem já usa as receitas entram aqui assim que forem enviados.
  </p>
  <div class="mt-10 grid gap-6 [grid-template-columns:repeat(auto-fit,minmax(260px,1fr))]">
    {Array.from({ length: PLACEHOLDER_COUNT }).map((_, i) => (
      <div
        class="reveal flex h-40 flex-col items-center justify-center gap-2 rounded-lg border-2 border-dashed border-border p-6 text-center text-text-muted"
        data-reveal-delay={(i * 0.08).toFixed(2)}
      >
        <p class="text-sm font-bold uppercase tracking-[0.1em]">Pendente</p>
        <p class="text-sm">Depoimento real do cliente entra aqui</p>
      </div>
    ))}
  </div>
</section>
