---
/**
 * Identificacao — "Isso soa familiar?", etapa Problema do framework
 * Problema → História Real → Resultados Específicos → Próximo Passo
 * (cerebro/raw/nichos/infoprodutos/_sintese.md, caso CursoOnline1).
 * Específico deste projeto — não faz parte da biblioteca reutilizável.
 */
interface Props {
  titulo: string;
  itens: string[];
}

const { titulo, itens } = Astro.props;
---

<section class="bg-surface-alt">
  <div class="container-du section-y">
    <h2 class="reveal text-center text-3xl font-bold text-text md:text-4xl">{titulo}</h2>
    <ul class="mt-10 grid gap-4 [grid-template-columns:repeat(auto-fit,minmax(260px,1fr))]">
      {itens.map((item, i) => (
        <li
          class="reveal flex items-start gap-3 rounded-lg bg-surface p-6 text-text-muted shadow-sm"
          data-reveal-delay={(i * 0.08).toFixed(2)}
        >
          <span aria-hidden="true" class="mt-0.5 flex-none font-display text-xl font-bold text-accent-600">?</span>
          <p>{item}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
