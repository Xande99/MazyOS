---
/**
 * LogoWall — marcas com quem o Video e Tal já trabalhou. Seção
 * específica deste projeto (fora da biblioteca cross-nicho de
 * src/sections/README.md) — prova de autoridade secundária: vem depois
 * de GaleriaProjetos na hierarquia da página, porque o trabalho em si
 * (a galeria) já é a prova primária ("mostra, não conta"); a logo wall
 * só reforça reconhecimento de marca.
 *
 * Grayscale → cor no hover é feito com duas cópias empilhadas da mesma
 * imagem (uma grayscale sempre visível, uma colorida por cima com
 * opacity 0→1 no hover/focus) — anima só `opacity`, nunca `filter`,
 * seguindo a regra não negociável de performance do projeto/CLAUDE.md.
 *
 * Mobile: scroll horizontal com snap. Desktop (md:): grid.
 */
interface LogoItem {
  nome: string;
  src: string;
  href?: string;
}

interface Props {
  logos: LogoItem[];
  titulo?: string;
}

const { logos, titulo } = Astro.props;
---

<section class="container-du section-y" aria-label={titulo ?? "Marcas que já trabalhei"}>
  {titulo && (
    <h2 class="reveal text-center text-3xl font-bold text-text md:text-4xl">{titulo}</h2>
  )}
  <div
    class:list={[
      "flex snap-x snap-mandatory gap-10 overflow-x-auto pb-2 md:grid md:snap-none md:[grid-template-columns:repeat(auto-fit,minmax(120px,1fr))] md:gap-12 md:overflow-visible md:pb-0",
      titulo && "mt-10",
    ]}
  >
    {logos.map((logo, i) =>
      logo.href ? (
        <a
          href={logo.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={logo.nome}
          class="reveal group relative h-12 w-32 flex-none snap-start md:h-14 md:w-full"
          data-reveal-delay={(i * 0.06).toFixed(2)}
        >
          <img
            src={logo.src}
            alt=""
            width={160}
            height={56}
            loading="lazy"
            class="absolute inset-0 h-full w-full object-contain grayscale opacity-60"
          />
          <img
            src={logo.src}
            alt=""
            aria-hidden="true"
            width={160}
            height={56}
            loading="lazy"
            class="absolute inset-0 h-full w-full object-contain opacity-0 transition-opacity duration-300 group-hover:opacity-100 group-focus-visible:opacity-100"
          />
        </a>
      ) : (
        <div
          class="reveal group relative h-12 w-32 flex-none snap-start md:h-14 md:w-full"
          data-reveal-delay={(i * 0.06).toFixed(2)}
        >
          <img
            src={logo.src}
            alt={logo.nome}
            width={160}
            height={56}
            loading="lazy"
            class="absolute inset-0 h-full w-full object-contain grayscale opacity-60"
          />
          <img
            src={logo.src}
            alt=""
            aria-hidden="true"
            width={160}
            height={56}
            loading="lazy"
            class="absolute inset-0 h-full w-full object-contain opacity-0 transition-opacity duration-300 group-hover:opacity-100 group-focus-visible:opacity-100"
          />
        </div>
      ),
    )}
  </div>
</section>
