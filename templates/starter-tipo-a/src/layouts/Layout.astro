---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  /** Caminho relativo em public/ pra imagem de compartilhamento (og:image). Opcional. */
  ogImage?: string;
  /** Marca a página como noindex/nofollow — usar em rotas internas (ex: /styleguide) que não devem aparecer em busca. */
  noindex?: boolean;
}

const { title, description, ogImage, noindex } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Preload da fonte de display — evita layout shift no maior texto acima
// da dobra (LCP). Default = Bricolage Grotesque (linha visual da duPolvo,
// self-hosted em public/fonts/) — vale pra todo projeto que herda essa
// linha (Passo 1.2 do /novo-projeto).
//
// Projeto com tipografia própria (Passo 1.3 do /novo-projeto — nicho com
// _tipografia.md ou fallback Manrope+Inter): Passo 3.5 troca estas duas
// linhas pelo import Vite da fonte Fontsource escolhida, ex:
//   import preloadFontHref from "@fontsource-variable/manrope/files/manrope-latin-wght-normal.woff2?url";
//   const preloadFontType = "font/woff2";
// O sufixo `?url` resolve pro caminho final com hash do build — nunca
// hardcodar o caminho, o Fontsource não garante nome de arquivo estável
// entre versões. Padrão de nome confirmado em teste real (2026-07-21):
// `<slug>-latin-wght-normal.woff2` é consistente entre fontes de eixo
// único (Manrope, Plus Jakarta Sans) e multi-eixo (Inter, com opsz+wght).
const preloadFontHref = "/fonts/BricolageGrotesque_36pt-ExtraBold.ttf";
const preloadFontType = "font/ttf";
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Preload da fonte de display — evita layout shift no maior texto acima da dobra (LCP). Ver frontmatter. -->
    <link
      rel="preload"
      href={preloadFontHref}
      as="font"
      type={preloadFontType}
      crossorigin
    />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={new URL(ogImage, Astro.site)} />}

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    {ogImage && <meta property="twitter:image" content={new URL(ogImage, Astro.site)} />}

    <ClientRouter />
  </head>
  <body>
    <slot />
    <script src="../scripts/reveal.ts"></script>
  </body>
</html>
